PORT=3001
NODE_ENV=development

DATABASE_URL=postgresql://localhost:5432/code_review_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=code_review_db
DB_USER=postgres
DB_PASSWORD=your_password

JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AI Provider (qwen/glm/deepseek)
AI_PROVIDER=qwen
AI_API_KEY=your_ai_api_key
AI_MODEL=qwen-plus-latest
# AI_BASE_URL=  # optional override

# Legacy GLM (fallback if AI_API_KEY not set)
GLM5_API_KEY=your_glm5_api_key
GLM5_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# XianGuanJia
XGJ_APP_KEY=your_xgj_app_key
XGJ_APP_SECRET=your_xgj_app_secret
XGJ_BASE_URL=https://open.goofish.pro

# Aliyun OSS
OSS_ACCESS_KEY_ID=
